{
  "name": "dialer-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade outbound predictive dialer platform",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @dialer/shared build && pnpm --parallel -r --filter=!@dialer/shared run dev",
    "dev:watch": "pnpm --parallel -r run dev",
    "build": "pnpm --filter @dialer/shared build && pnpm -r --filter=!@dialer/shared run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  }
}
