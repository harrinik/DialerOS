# ============================================================
# DIALER PLATFORM — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in real values.
# NEVER commit a populated .env file.
# ============================================================

# ---- Node ----
NODE_ENV=development

# ---- MongoDB ----
# Local dev: mongodb://localhost:27017/dialer
# Docker:    mongodb://mongo:27017/dialer
# Atlas:     mongodb+srv://<user>:<pass>@cluster.mongodb.net/dialer
MONGODB_URI=mongodb://localhost:27017/dialer
MONGODB_DB=dialer

# ---- Redis ----
# Local dev: 127.0.0.1
# Docker:    redis  (service name)
# Cloud:     your Redis host
# IMPORTANT: Redis must use maxmemory-policy=noeviction for BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- API ----
API_PORT=3000
API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Asterisk ARI ----
# Local dev:  localhost  (Asterisk on this machine)
# Docker:     host.docker.internal  (Asterisk on the host, app in container)
# DO NOT use 'asterisk' — that's only valid if Asterisk itself runs in Docker
ARI_HOST=localhost
ARI_PORT=8088
ARI_USERNAME=dialer
ARI_PASSWORD=change_me_ari_password
ARI_APP_NAME=dialer
ARI_TLS=false
ARI_RECONNECT_INITIAL_DELAY_MS=1000
ARI_RECONNECT_MAX_DELAY_MS=60000

# ---- Asterisk AMI ----
AMI_HOST=localhost
AMI_PORT=5038
AMI_USER=dialer
AMI_PASSWORD=change_me_ami_password

# ---- Asterisk Directories ----
AST_SOUNDS_DIR=/var/lib/asterisk/sounds/dialer
AST_RECORDINGS_DIR=/var/spool/asterisk/monitor
ASTERISK_CONF_DIR=/etc/asterisk

# ---- Dialer Worker ----
WORKER_CONCURRENCY=10
WORKER_RATE_LIMIT_MAX=10
WORKER_RATE_LIMIT_DURATION=1000

# ---- Pacing (Erlang-C) ----
PACING_TARGET_OCCUPANCY=0.85
PACING_SERVICE_LEVEL_TARGET=0.95
PACING_ANSWER_RATE_WINDOW_SECONDS=300
PACING_MIN_CALLS_PER_SECOND=1
PACING_MAX_CALLS_PER_SECOND=100

# ---- Realtime Gateway ----
GATEWAY_PORT=3001
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001

# ---- DNC ----
DNC_REDIS_KEY_PREFIX=dnc:

# ---- Logging ----
LOG_LEVEL=info

# ---- Update Webhook (optional) ----
# Set this to enable GitHub webhook auto-deploy to POST /api/admin/update
UPDATE_WEBHOOK_SECRET=
PROJECT_DIR=/opt/dialer
